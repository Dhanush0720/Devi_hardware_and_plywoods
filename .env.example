# MongoDB
MONGODB_URI=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=INR

# Google APIs (location/maps only — NOT used for stock logic)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
SHOP_GOOGLE_PLACE_ID=your_shop_place_id_here

# WhatsApp Business Platform (Meta Cloud API)
# Leave blank until you have a Meta Business + WhatsApp Business app.
# When WHATSAPP_ENABLED is false, the app logs messages instead of sending them,
# so you can build/test everything else first.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_ORDER_TEMPLATE_NAME=order_confirmation_invoice

# Invoice storage
# "local" stores PDFs under /public/invoices (fine for quick start / Vercel ephemeral testing).
# For production on Vercel, switch to an object storage provider (S3, Cloudinary, etc.)
# since Vercel's filesystem is read-only/ephemeral in production.
INVOICE_STORAGE=local

# Admin auth (simple shared-secret guard for the admin dashboard — replace with real auth in production)
ADMIN_SESSION_SECRET=change_this_to_a_long_random_string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=123456789
